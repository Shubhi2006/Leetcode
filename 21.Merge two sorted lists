class Solution {
    public ListNode mergeTwoLists(ListNode list1, ListNode list2) {
        ListNode dummy = new ListNode(0);
        ListNode merge = dummy;
        ListNode l1=list1;
        ListNode l2=list2;
        while(l1!=null && l2!=null ){
            if(l1.val<=l2.val){
                merge.next=new ListNode(l1.val);
                l1=l1.next;
            }
            else{
                merge.next=new ListNode(l2.val);
                l2=l2.next;
            }
            merge=merge.next;

        }
        while(l1!=null){
            merge.next=new ListNode(l1.val);
            merge=merge.next;
            l1=l1.next;
        }
        while(l2!=null){
            merge.next=new ListNode(l2.val);
            merge=merge.next;
            l2=l2.next;
        }
        return dummy.next;
    }
}
