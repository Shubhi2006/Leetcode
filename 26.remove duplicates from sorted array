class Solution {
    public int removeDuplicates(int[] nums) {
        int arr[]=new int[nums.length];
        int pos=1;
        arr[0]=nums[0];
        for(int i=1;i<nums.length;i++){
            if(nums[i]==nums[i-1] ){
               continue;
            }
            else{
                nums[pos]=nums[i];
                pos++;
            }
        }
        return pos;

    }
}
