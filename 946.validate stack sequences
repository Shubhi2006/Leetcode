class Solution {
    public boolean validateStackSequences(int[] pushed, int[] popped) {
        int max=Math.max(pushed.length,popped.length);
        Stack<Integer>st=new Stack<>();
        int j=0;
        for(int i=0;i<pushed.length;i++){
            st.push(pushed[i]);
            if(st.peek()!=popped[j]){
                continue;
            }
            while(!st.isEmpty() && st.peek()==popped[j]){
                st.pop();
                j++;
            }
        }
        if(st.isEmpty()){
            return true;
        }
        else{
            return false;
        }
    }
}
