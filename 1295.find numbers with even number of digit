class Solution {
    public int findNumbers(int[] nums) {
        int count=0;
        for(int num:nums){
            int temp=num;
            int digit=0;
            while(temp>0){
                digit++;
                temp=temp/10;
            }
            if(digit%2==0){
                count++;
            }

        }
        return count;
    }
}
